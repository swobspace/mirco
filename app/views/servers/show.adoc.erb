== Connectoren

=== Source Connectors

<%= render 'servers/connectors',
           connectors: @server.channels
                              .map{|c| c.source_connector}
                              .reject{|conn| conn&.url.nil?}
 %>



=== Destination Connectors

<%= render 'servers/connectors',
           connectors: @server.channels
                              .map{|c| c.destination_connectors}
                              .flatten
                              .reject{|conn| conn&.url.nil?}
 %>

